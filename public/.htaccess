AuthType Basic
AuthName "Scam.me - Accès restreint"
AuthUserFile /home/xouindap/www/scam-me/.htpasswd
Require valid-user

# URLs propres sans .html
Options -MultiViews
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
