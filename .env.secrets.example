# ══════════════ SECRETS BOT STEAM ══════════════
# ⚠️  NE JAMAIS COMMIT CE FICHIER — il est dans .gitignore
# Copier ce fichier en .env.secrets et remplir les valeurs.
#
# Pour extraire shared_secret + identity_secret :
#   1. Installer Steam Desktop Authenticator (SDA)
#   2. Importer le compte Steam dans SDA
#   3. Ouvrir le .maFile dans le dossier maFiles/
#   4. Copier shared_secret et identity_secret

# Identifiants du compte bot Steam
BOT_ACCOUNT_NAME=""
BOT_PASSWORD=""

# Secrets 2FA — en clair en dev, chiffrés en prod
# shared_secret : génère les codes 2FA automatiquement
BOT_SHARED_SECRET=""
# identity_secret : confirme les trade offers sans intervention
BOT_IDENTITY_SECRET=""

# Mettre à "true" en prod si les secrets ci-dessus sont chiffrés (AES-256-GCM)
BOT_SECRETS_ENCRYPTED="false"

# Clé de chiffrement pour les secrets en prod (32 bytes)
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=""
